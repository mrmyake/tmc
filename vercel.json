{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/generate-sessions",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/expire-strikes",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/waitlist-promote",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/release-no-shows",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/refresh-kpis",
      "schedule": "50 3 * * *"
    },
    {
      "path": "/api/cron/process-cancellations",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/flag-dropoff",
      "schedule": "10 4 * * *"
    },
    {
      "path": "/api/cron/check-milestones",
      "schedule": "20 4 * * *"
    },
    {
      "path": "/api/cron/cleanup-workout-sessions",
      "schedule": "40 3 * * *"
    },
    {
      "path": "/api/cron/release-early-member-holds",
      "schedule": "25 4 * * *"
    }
  ]
}
